<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>{{PANE_TITLE}}</title>
    <style>
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        margin: 0;
        padding: 12px;
        background: #f5f5f5;
        color: #333;
      }

      h1 {
        font-size: 16px;
        margin: 0 0 8px 0;
      }

      .subtitle {
        font-size: 12px;
        color: #666;
        margin-bottom: 12px;
      }

      .status {
        font-size: 12px;
        margin-bottom: 8px;
      }

      .status.loading {
        color: #005a9e;
      }

      .status.error {
        color: #a80000;
      }

      table {
        width: 100%;
        border-collapse: collapse;
        background: #fff;
      }

      thead {
        background: #f3f2f1;
      }

      th,
      td {
        padding: 6px 8px;
        font-size: 12px;
        text-align: left;
        border-bottom: 1px solid #e1dfdd;
      }

      th {
        font-weight: 600;
      }

      tbody tr:nth-child(even) {
        background: #faf9f8;
      }

      .jobs-badge {
        display: inline-block;
        min-width: 24px;
        padding: 2px 6px;
        border-radius: 10px;
        text-align: center;
        background: #eaeaea;
      }

      .jobs-badge.zero {
        background: #f3f2f1;
        color: #605e5c;
      }

      .jobs-badge.nonzero {
        background: #dff6dd;
        color: #107c10;
      }

      .btn-assign {
        margin-left: 6px;
        padding: 4px 10px;
        font-size: 11px;
        border: 1px solid #0078d4;
        background: #0078d4;
        color: #fff;
        border-radius: 4px;
        cursor: pointer;
        white-space: nowrap;
      }

      .btn-assign:hover {
        background: #106ebe;
      }
    </style>
  </head>
  <body>
    <h1 id="title">{{PANE_TITLE}}</h1>
    <div id="subtitle" class="subtitle"></div>
    <div id="status" class="status loading">Loading...</div>

    <table aria-label="{{PANE_TITLE}}">
      <thead>
        <tr>
          <th>Employee</th>
          <th style="width: 100px; text-align: center">Jobs</th>
          <th style="width: 70px"></th>
        </tr>
      </thead>
      <tbody id="rowsContainer">
        <!-- Rows filled dynamically by JavaScript -->
      </tbody>
    </table>

    <script>
      (function () {
        'use strict';

        // Entity logical names (singular) for Xrm.WebApi.retrieveMultipleRecords:
        // Maintenance Team Member table
        const ENTITY_TEAM_MEMBER = '{{ENTITY_TEAM_MEMBER}}';
        const FIELD_TEAM_LOOKUP = '{{FIELD_TEAM_LOOKUP}}';
        const FIELD_EMPLOYEE_LOOKUP = '{{FIELD_EMPLOYEE_LOOKUP}}';
        const FIELD_EMPLOYEE_NAME = '{{FIELD_EMPLOYEE_NAME}}';

        // Work Order / parent entity table
        const ENTITY_WORK_ORDER = '{{ENTITY_WORK_ORDER}}';
        const FIELD_WO_EMPLOYEE_LOOKUP = '{{FIELD_WO_EMPLOYEE_LOOKUP}}';
        const FIELD_WO_SCHEDULE_DATE = '{{FIELD_WO_SCHEDULE_DATE}}';

        function assignEmployee(employeeId, employeeName) {
          if (!employeeId) return;
          var id = (employeeId + '').replace(/[{}]/g, '');
          var name = employeeName || '';

          function showError(msg) {
            if (parent && parent.Xrm && parent.Xrm.Navigation) {
              parent.Xrm.Navigation.openAlertDialog({ title: 'Assign Employee', text: msg });
            }
          }

          try {
            var data = getQueryData();
            var recordId = data && data.recordId ? (data.recordId + '').replace(/[{}]/g, '') : null;

            if (recordId && parent && parent.Xrm && parent.Xrm.WebApi) {
              var updatePayload = {};
              var navProp = '{{WO_EMPLOYEE_NAV_PROPERTY}}';
              var targetSet = '{{WO_EMPLOYEE_TARGET_SET}}';
              updatePayload[navProp + '@odata.bind'] = '/' + targetSet + '(' + id + ')';
              return parent.Xrm.WebApi.updateRecord(ENTITY_WORK_ORDER, recordId, updatePayload)
                .then(function () {
                  var formCtx = (window.top || window).{{FORM_CONTEXT_GLOBAL}};
                  if (formCtx && formCtx.data && formCtx.data.refresh) {
                    formCtx.data.refresh();
                  }
                })
                .catch(function (err) {
                  showError('Update failed: ' + (err.message || String(err)));
                });
            }

            var formCtx = (window.top || window).{{FORM_CONTEXT_GLOBAL}};
            if (!formCtx || typeof formCtx.getAttribute !== 'function') {
              showError('Could not access the form. Close and reopen the pane.');
              return;
            }

            var attr = formCtx.getAttribute(FIELD_WO_EMPLOYEE_LOOKUP);
            if (!attr) {
              showError('Employee field not found on the form.');
              return;
            }

            attr.setValue([{ id: id, name: name }]);
          } catch (err) {
            console.error('[TeamMembersPane] Assign failed:', err);
            if (parent && parent.Xrm && parent.Xrm.Navigation) {
              parent.Xrm.Navigation.openAlertDialog({
                title: 'Error',
                text: 'Failed to assign employee: ' + (err.message || String(err)),
              });
            }
          }
        }

        function getScheduleDateFromForm() {
          try {
            var formCtx = (window.top || window).{{FORM_CONTEXT_GLOBAL}};
            if (!formCtx || typeof formCtx.getAttribute !== 'function') return null;
            var attr = formCtx.getAttribute(FIELD_WO_SCHEDULE_DATE);
            if (!attr) return null;
            var val = attr.getValue ? attr.getValue() : null;
            if (!val) return null;
            if (typeof val.getFullYear === 'function') {
              var y = val.getFullYear();
              var m = val.getMonth() + 1;
              var d = val.getDate();
              return y + '-' + (m < 10 ? '0' + m : m) + '-' + (d < 10 ? '0' + d : d);
            }
            if (typeof val === 'string' && val.length >= 10) {
              var s = val.substring(0, 10);
              return /^\d{4}-\d{2}-\d{2}$/.test(s) ? s : null;
            }
            return null;
          } catch (e) { return null; }
        }

        function getQueryData() {
          try {
            var data = null;

            try {
              var globalData = (window.top || window).{{PANEDATA_GLOBAL}};
              if (globalData && globalData.teamId) data = globalData;
            } catch (e) {}

            if (!data) {
              try {
                var stored = sessionStorage.getItem('{{PANEDATA_STORAGE_KEY}}');
                if (stored) data = JSON.parse(stored);
              } catch (e) {}
            }

            if (!data) {
              try {
                var search = window.location && window.location.search;
                if (search) {
                  var params = new URLSearchParams(search);
                  var dataParam = params.get('data') || params.get('Data');
                  if (dataParam) data = JSON.parse(decodeURIComponent(dataParam));
                }
              } catch (e) {}
            }

            if (!data) {
              try {
                if (parent && parent.Xrm && parent.Xrm.Utility) {
                  var qs = parent.Xrm.Utility.getGlobalContext().getQueryStringParameters();
                  if (qs && qs.data) data = JSON.parse(decodeURIComponent(qs.data));
                }
              } catch (e) {}
            }

            if (data && !data.scheduleDate) {
              var fromForm = getScheduleDateFromForm();
              if (fromForm) data.scheduleDate = fromForm;
            }

            return data;
          } catch (e) {
            console.error('[TeamMembersPane] Failed to read data parameter:', e);
            return null;
          }
        }

        function setStatus(message, cssClass) {
          var statusEl = document.getElementById('status');
          statusEl.textContent = message || '';
          statusEl.className = 'status' + (cssClass ? ' ' + cssClass : '');
        }

        function renderRows(members) {
          var container = document.getElementById('rowsContainer');
          container.innerHTML = '';

          if (!members.length) {
            var tr = document.createElement('tr');
            var td = document.createElement('td');
            td.colSpan = 3;
            td.textContent = 'No employees found for this maintenance team.';
            tr.appendChild(td);
            container.appendChild(tr);
            return;
          }

          members.forEach(function (m) {
            var tr = document.createElement('tr');

            var tdName = document.createElement('td');
            tdName.textContent = m.name || '(no name)';
            tr.appendChild(tdName);

            var tdJobs = document.createElement('td');
            tdJobs.style.textAlign = 'center';

            var span = document.createElement('span');
            span.className =
              'jobs-badge ' +
              (m.jobs && m.jobs > 0 ? 'nonzero' : 'zero');
            span.textContent = typeof m.jobs === 'number' ? m.jobs : '-';
            tdJobs.appendChild(span);

            tr.appendChild(tdJobs);

            var tdAssign = document.createElement('td');
            tdAssign.style.textAlign = 'center';
            var btn = document.createElement('button');
            btn.type = 'button';
            btn.className = 'btn-assign';
            btn.textContent = 'Assign';
            btn.title = '{{BUTTON_ASSIGN_TITLE}}';
            btn.onclick = function () {
              assignEmployee(m.id, m.name);
            };
            tdAssign.appendChild(btn);
            tr.appendChild(tdAssign);

            container.appendChild(tr);
          });
        }

        function getWebApi() {
          if (!parent || !parent.Xrm || !parent.Xrm.WebApi) {
            throw new Error('Xrm.WebApi is not available from parent.');
          }
          return parent.Xrm.WebApi;
        }

        function getTeamMembers(teamId) {
          var selectFields = '_' + FIELD_EMPLOYEE_LOOKUP + '_value,' + FIELD_EMPLOYEE_NAME;
          var query =
            '?$select=' + selectFields +
            '&$filter=_' + FIELD_TEAM_LOOKUP + '_value eq ' + teamId;

          return getWebApi()
            .retrieveMultipleRecords(ENTITY_TEAM_MEMBER, query)
            .then(function (result) {
              var list = result.entities.map(function (e) {
                return {
                  id: e['_' + FIELD_EMPLOYEE_LOOKUP + '_value'],
                  name: e[FIELD_EMPLOYEE_NAME],
                  jobs: 0,
                };
              });

              list.sort(function (a, b) {
                return (a.name || '').localeCompare(
                  b.name || '',
                  'en'
                );
              });

              return list;
            });
        }

        function fillJobsPerMember(members, scheduleDate, teamId) {
          if (!members.length) return Promise.resolve();

          if (!scheduleDate) {
            members.forEach(function (m) { m.jobs = 0; });
            return Promise.resolve();
          }

          var woEmployeeField = '{{WO_EMPLOYEE_FIELD_VALUE}}';
          var woTeamField = '{{WO_TEAM_FIELD_VALUE}}';

          var promises = members.map(function (m) {
            if (!m.id) {
              m.jobs = 0;
              return Promise.resolve();
            }

            var empGuid = (m.id || '').replace(/[{}]/g, '');
            var teamGuid = teamId ? (teamId + '').replace(/[{}]/g, '') : null;

            var filter = woEmployeeField + " eq '" + empGuid + "' and statecode eq 0";
            if (teamGuid) {
              filter += " and " + woTeamField + " eq '" + teamGuid + "'";
            }
            filter += " and Microsoft.Dynamics.CRM.On(PropertyName='" + FIELD_WO_SCHEDULE_DATE + "',PropertyValue='" + scheduleDate + "')";

            var query = "?$select={{ENTITY_WORK_ORDER_PK}}&$filter=" + encodeURIComponent(filter);

            return getWebApi()
              .retrieveMultipleRecords(ENTITY_WORK_ORDER, query)
              .then(function (res) {
                m.jobs = res.entities.length;
              })
              .catch(function (err) {
                console.warn('[TeamMembersPane] Jobs count for', m.name, err.message || err);
                m.jobs = 0;
              });
          });

          return Promise.all(promises);
        }

        function init() {
          var data = getQueryData();
          if (!data || !data.teamId) {
            setStatus(
              'No team data (teamId) found. Close the pane and try again.',
              'error'
            );
            return;
          }

          var subtitleParts = [];
          if (data.teamName) subtitleParts.push('Team: ' + data.teamName);
          if (data.scheduleDate) {
            subtitleParts.push('Date: ' + data.scheduleDate);
          } else {
            subtitleParts.push('Scheduled date not selected');
          }
          document.getElementById('subtitle').textContent =
            subtitleParts.join('  •  ');

          setStatus('Loading employees...', 'loading');

          getTeamMembers(data.teamId)
            .then(function (members) {
              return fillJobsPerMember(members, data.scheduleDate, data.teamId).then(
                function () {
                  return members;
                }
              );
            })
            .then(function (members) {
              setStatus(
                data.scheduleDate ? '' : 'You have not selected a Scheduled date. Job counts require a date on the Work Order form.',
                data.scheduleDate ? '' : 'error'
              );
              renderRows(members);
            })
            .catch(function (error) {
              console.error('[TeamMembersPane] Error:', error);
              setStatus(
                'An error occurred while loading the data.',
                'error'
              );
            });
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', init);
        } else {
          init();
        }
      })();
    </script>
  </body>
</html>
