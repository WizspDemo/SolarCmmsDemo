  Title varchar(255) [not null, note: 'Category name']
  Description text
  MainType varchar(50) [note: 'Equipment or Asset']
  ParentId int [ref: > EquipmentCategories.id, note: 'Self-referencing hierarchical']
  CategoryType varchar(255)
  Notes text
  Active boolean [default: true]
  Created timestamp [default: `now()`]
  Modified timestamp [default: `now()`]
  
  Note: 'Hierarchical categories for equipment classification'
  
  Indexes {
    Code [name: 'idx_equipcat_code']
    ParentId [name: 'idx_equipcat_parent']
    Active [name: 'idx_equipcat_active']
  }
}

