  Level varchar(50) [default: 'Category Level #1']
  ParentId int [ref: > PartsCategories.id, note: 'Self-referencing hierarchical']
  Notes text
  Active boolean [default: true]
  Created timestamp [default: `now()`]
  Modified timestamp [default: `now()`]
  
  Note: 'Hierarchical categories for parts (3 levels)'
  
  Indexes {
    Code [name: 'idx_partscat_code']
