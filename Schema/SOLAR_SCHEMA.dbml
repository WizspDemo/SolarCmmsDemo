// Solar Plant Maintenance Management System - Database Schema
// Generated from unified schema files
// Total Tables: 67 | Total Relationships: 73

Project SolarMaintenanceSystem {
  database_type: 'PostgreSQL'
  Note: '''
    Complete Solar Plant Maintenance Management System
    Covers: Location management, Equipment tracking, Parts inventory,
    Preventive & Corrective maintenance, Team management, and Document control
  '''
}

// ========================================
// TABLE GROUP: Master Data
// ========================================

TableGroup MasterData {
  Countries
  Suppliers
  ManufacturerBrands
  DNO
  Accounts
  ServiceCompanys
}

Table Countries {
  id int [pk, increment]
  Title varchar(255) [not null, note: 'Country name']
  ISOAlpha2 varchar(2) [note: '2-letter ISO code']
  ISOALPHA3 varchar(3) [note: '3-letter ISO code']
  Created timestamp [default: `now()`]
  Modified timestamp [default: `now()`]
  
  Note: 'Master list of countries for location reference'
  
  Indexes {
    Title [name: 'idx_countries_title']
    ISOAlpha2 [name: 'idx_countries_iso2']
  }
}

Table Suppliers {
  id int [pk, increment]
  Code varchar(255) [unique, note: 'Unique supplier code']
  Title varchar(255) [not null, note: 'Supplier name']
  Description text
  Notes text
  Active boolean [default: true]
  Created timestamp [default: `now()`]
  Modified timestamp [default: `now()`]
  
  Note: 'Suppliers for equipment and parts'
  
  Indexes {
    Code [name: 'idx_suppliers_code']
    Active [name: 'idx_suppliers_active']
  }
}

Table ManufacturerBrands {
  id int [pk, increment]
  Code varchar(255) [unique]
  Title varchar(255) [not null, note: 'Brand/Manufacturer name']
  Logo varchar(255)
  Description text
  Website varchar(500)
  Notes text
  Active boolean [default: true]
  Created timestamp [default: `now()`]
  Modified timestamp [default: `now()`]
  
  Note: 'Manufacturer and brand information for equipment/parts'
  
  Indexes {
    Code [name: 'idx_manufacturers_code']
    Active [name: 'idx_manufacturers_active']
  }
}

Table DNO {
  id int [pk, increment]
  Code varchar(255)
  Title varchar(255) [not null, note: 'Distribution Network Operator name']
  EmergencyNumber varchar(255)
  Description text
  Telephone varchar(255)
  Email varchar(255)
  Website varchar(500)
  Notes text
  Created timestamp [default: `now()`]
  Modified timestamp [default: `now()`]
  
  Note: 'Distribution Network Operators (Grid Operators)'
  
  Indexes {
    Code [name: 'idx_dno_code']
  }
}

Table Accounts {
  id int [pk, increment]
  Code varchar(255) [unique]
  Title varchar(255) [not null, note: 'Account name']
  DistinctiveTitle varchar(255)
  Description text
  AddressDescription text
  Street varchar(255)
  ZipOrPostalCode varchar(255)
  City varchar(255)
  StateOrProvince varchar(255)
  CountryId int [ref: > Countries.id, note: 'FK to Countries']
  Telephone varchar(255)
  Email varchar(255)
  ManagerId int [note: 'User reference']
  Notes text
  Created timestamp [default: `now()`]
  Modified timestamp [default: `now()`]
  
  Note: 'Client accounts/organizations'
  
  Indexes {
    Code [name: 'idx_accounts_code']
    CountryId [name: 'idx_accounts_country']
  }
}

Table ServiceCompanys {
  id int [pk, increment]
  Code varchar(255) [unique]
  Title varchar(255) [not null, note: 'Service company name']
  Description text
  ContactPerson varchar(255)
  Email varchar(255)
  Phone varchar(255)
  Website varchar(500)
  Notes text
  Active boolean [default: true]
  Created timestamp [default: `now()`]
  Modified timestamp [default: `now()`]
  
  Note: 'External service providers for maintenance'
  
  Indexes {
    Code [name: 'idx_servicecompany_code']
    Active [name: 'idx_servicecompany_active']
  }
}

