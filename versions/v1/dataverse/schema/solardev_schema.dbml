// Relationships (only between solardev tables)
Ref: solar_solarpreventivetask.solar_park > solar_location.solar_locationid
Ref: solar_solarpreventiveplan.solar_planlocation > solar_location.solar_locationid
Ref: solar_corrective_work_order.solar_locationid > solar_location.solar_locationid
Ref: solar_solarmodule.solar_park > solar_location.solar_locationid
Ref: solar_solarinverter.solar_park > solar_location.solar_locationid
Ref: solar_location.solar_parkmanager > account.accountid
Ref: solar_location.solar_account > new_account.new_accountid
Ref: solar_corrective_work_order.solar_maintenanceteamid > solar_maintenance_team.solar_maintenance_teamid
Ref: solar_corrective_work_order.solar_team > solar_maintenance_team.solar_maintenance_teamid
Ref: solar_solarpreventivetask.solar_solarpreventivetaskcategory > solar_solarpreventivetaskcategory.solar_solarpreventivetaskcategoryid
Ref: account.parentaccountid > account.accountid
Ref: account.msa_managingpartnerid > account.accountid
Ref: contact.msa_managingpartnerid > account.accountid
Ref: account.masterid > account.accountid
Ref: contact.parentcustomerid > account.accountid
Ref: account.primarycontactid > contact.contactid
Ref: solar_solarpreventiveplan.solar_plancategory > solar_solarpreventiveplancategory.solar_solarpreventiveplancategoryid
Ref: solar_task.solar_workorderid > solar_corrective_work_order.solar_corrective_work_orderid
Ref: solar_corrective_work_order.solar_categoryid > solar_corrective_category.solar_corrective_categoryid
Ref: solar_corrective_work_order.solar_employee > new_account.new_accountid