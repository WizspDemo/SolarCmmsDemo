      { "proposed_entity_name": "solar_asset", "sharepoint_source": "Assets", "primary_name_attribute": "solar_name", "description": "Assets ανά location/section.", "relationship_to_solar_location": "solar_location → solar_location", "key_lookups": ["Category → solar_asset_category", "Location → solar_location", "Section → solar_section", "ManufacturerOrBrand → solar_manufacturer_brand"], "key_attributes_from_sharepoint": ["Code", "Title", "Category", "Description", "Location", "Section", "SerialNumber", "ManufacturerOrBrand", "InstallationDate", "WarrantyExpiry", "Notes", "Active"] },
