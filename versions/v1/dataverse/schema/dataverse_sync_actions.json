      { "proposed_entity_name": "solar_maintenance_team_member", "sharepoint_source": "MaintenanceTeamMembers", "primary_name_attribute": "solar_name", "description": "Μέλη ομάδας συντήρησης.", "key_lookups": ["MaintenanceTeam → solar_maintenance_team"], "key_attributes_from_sharepoint": ["Title", "MaintenanceTeam", "Member", "Role", "StartDate", "EndDate", "Active"] },
      { "proposed_entity_name": "solar_service_company", "sharepoint_source": "ServiceCompanys", "primary_name_attribute": "solar_name", "description": "Εταιρείες υπηρεσιών.", "key_attributes_from_sharepoint": ["Code", "Title", "Description", "ContactPerson", "Email", "Phone", "Website", "Notes", "Active"] },
