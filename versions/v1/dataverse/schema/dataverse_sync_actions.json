      { "proposed_entity_name": "solar_document_set_category", "sharepoint_source": "DocumentSetCategories", "primary_name_attribute": "solar_name", "description": "Κατηγορίες εγγράφων." },
      { "proposed_entity_name": "solar_document_set", "sharepoint_source": "DocumentSets", "primary_name_attribute": "solar_name", "description": "Σετ εγγράφων.", "key_lookups": ["Category → solar_document_set_category"], "key_attributes_from_sharepoint": ["Title", "Category", "Comments"] },
      { "proposed_entity_name": "solar_parts_transaction", "sharepoint_source": "PartsTransaction", "primary_name_attribute": "solar_name", "description": "Κινήσεις ανταλλακτικών.", "key_lookups": ["Part → solar_part", "FromWarehouse → solar_warehouse", "ToWarehouse → solar_warehouse"], "key_attributes_from_sharepoint": ["Title", "Part", "TransactionType", "Quantity", "FromWarehouse", "ToWarehouse", "TransactionDate", "Notes"] },
