      { "proposed_entity_name": "solar_equipment", "sharepoint_source": "Equipment", "primary_name_attribute": "solar_name", "description": "Εξοπλισμός.", "key_lookups": ["Category → solar_equipment_category", "ManufacturerOrBrand → solar_manufacturer_brand", "Supplier → solar_supplier"], "key_attributes_from_sharepoint": ["Code", "Title", "Category", "Description", "ManufacturerID", "ManufacturerOrBrand", "Supplier", "StockManagement", "Photo", "URL", "Notes", "Active", "Serial"] },
      { "proposed_entity_name": "solar_part", "sharepoint_source": "Parts", "primary_name_attribute": "solar_name", "description": "Ανταλλακτικά.", "key_lookups": ["Category → solar_part_category", "ManufacturerOrBrand → solar_manufacturer_brand", "Supplier → solar_supplier"], "key_attributes_from_sharepoint": ["Code", "Title", "Category", "Description", "Barcode", "UPC", "ManufacturerOrBrand", "Supplier", "StockManagement", "Consumable", "Photo", "URL", "MinQTY", "Notes", "Active"] },
