{
  "metadata": {
    "purpose": "Τροποποιήσεις υπαρχόντων πινάκων, δημιουργία νέων πινάκων, συνδέσεις. Βασικό entity Solar Plant: Locations (solar_location), όχι PVPlants.",
    "source_sharepoint": "Sharepoint/PreFinal schema/schema.dbml",
    "target_dataverse": "dataverse/schema/solardev_schema.dbml",
    "primary_entity_solar_plant": "solar_location"
  },
  "modify_existing_tables": [
    {
      "dataverse_table": "solar_location",
      "sharepoint_source": "Locations",
      "description": "Βασικός πίνακας Solar Plant. Προσθήκη attributes που λείπουν από SharePoint Locations.",
      "add_attributes": [
        { "logical_name": "solar_code", "type": "SingleLine", "max_length": 255, "sharepoint_column": "Code", "is_unique": true },
        { "logical_name": "solar_annualoutputgwh", "type": "Decimal", "sharepoint_column": "AnnualOutputGWh" },
        { "logical_name": "solar_contains_sections", "type": "Boolean", "sharepoint_column": "ContainsSections" },
        { "logical_name": "solar_description", "type": "Multiline", "sharepoint_column": "Description" },
        { "logical_name": "solar_landsizehectares", "type": "Decimal", "sharepoint_column": "LandSizeHectares" },
        { "logical_name": "solar_addressdescription", "type": "Multiline", "sharepoint_column": "AddressDescription" },
        { "logical_name": "solar_googleearth", "type": "SingleLine", "sharepoint_column": "GoogleEarth" },
        { "logical_name": "solar_embedmap", "type": "Multiline", "sharepoint_column": "EmbedMap" },
        { "logical_name": "solar_what3words", "type": "SingleLine", "sharepoint_column": "What3Words" },
        { "logical_name": "solar_grazed", "type": "Boolean", "sharepoint_column": "Grazed" },
        { "logical_name": "solar_landownerfarmerdetails", "type": "Multiline", "sharepoint_column": "LandOwnerFarmerDetails" },
        { "logical_name": "solar_modulemanufacturer", "type": "SingleLine", "sharepoint_column": "ModuleManufacturer" },
        { "logical_name": "solar_modulemodel", "type": "SingleLine", "sharepoint_column": "ModuleModel" },
        { "logical_name": "solar_modulequantity", "type": "Decimal", "sharepoint_column": "ModuleQuantity" },
        { "logical_name": "solar_modulepower", "type": "Decimal", "sharepoint_column": "ModulePower" },
        { "logical_name": "solar_modulevoc", "type": "Decimal", "sharepoint_column": "ModuleVoc" },
        { "logical_name": "solar_moduleisc", "type": "Decimal", "sharepoint_column": "ModuleIsc" },
        { "logical_name": "solar_modulelength", "type": "Decimal", "sharepoint_column": "ModuleLength" },
        { "logical_name": "solar_modulewidth", "type": "Decimal", "sharepoint_column": "ModuleWidth" },
        { "logical_name": "solar_moduledepth", "type": "Decimal", "sharepoint_column": "ModuleDepth" },
        { "logical_name": "solar_modulestructure", "type": "SingleLine", "sharepoint_column": "ModuleStructure" },
        { "logical_name": "solar_satellite3g4g", "type": "SingleLine", "sharepoint_column": "Satellite3G4G" },
        { "logical_name": "solar_lannetwork", "type": "SingleLine", "sharepoint_column": "LANNetwork" },
        { "logical_name": "solar_scadaprovider", "type": "SingleLine", "sharepoint_column": "SCADAProvider" },
        { "logical_name": "solar_adasinstalled", "type": "Boolean", "sharepoint_column": "ADASInstalled" },
        { "logical_name": "solar_dataloggers", "type": "SingleLine", "sharepoint_column": "DataLoggers" },
        { "logical_name": "solar_dnosizekv", "type": "SingleLine", "sharepoint_column": "DNOSizeKV" },
        { "logical_name": "solar_dnocontact", "type": "SingleLine", "sharepoint_column": "DNOContact" },
        { "logical_name": "solar_dnocontact2", "type": "SingleLine", "sharepoint_column": "DNOContact2" },
        { "logical_name": "solar_dnocontact3", "type": "SingleLine", "sharepoint_column": "DNOContact3" },
        { "logical_name": "solar_sitereferencenumber", "type": "SingleLine", "sharepoint_column": "SiteReferenceNumber" },
        { "logical_name": "solar_hvcontractor", "type": "SingleLine", "sharepoint_column": "HVContractor" },
        { "logical_name": "solar_tbootsub", "type": "SingleLine", "sharepoint_column": "TBootSub" },
        { "logical_name": "solar_transformerquantity", "type": "Decimal", "sharepoint_column": "TransformerQuantity" },
        { "logical_name": "solar_transformermake", "type": "SingleLine", "sharepoint_column": "TransformerMake" },
        { "logical_name": "solar_transformermodel", "type": "SingleLine", "sharepoint_column": "TransformerModel" },
        { "logical_name": "solar_transformerratingkva", "type": "Decimal", "sharepoint_column": "TransformerRatingKVA" },
        { "logical_name": "solar_security", "type": "SingleLine", "sharepoint_column": "Security" },
        { "logical_name": "solar_securitycodes", "type": "Multiline", "sharepoint_column": "SecurityCodes" },
        { "logical_name": "solar_siteaccessdetails", "type": "Multiline", "sharepoint_column": "SiteAccessDetails" },
        { "logical_name": "solar_accessgatecodes", "type": "Multiline", "sharepoint_column": "AccessGateCodes" },
        { "logical_name": "solar_exportmeterlocation", "type": "SingleLine", "sharepoint_column": "ExportMeterLocation" },
        { "logical_name": "solar_exportmeteraccessdetails", "type": "Multiline", "sharepoint_column": "ExportMeterAccessDetails" },
        { "logical_name": "solar_otherinformation", "type": "Multiline", "sharepoint_column": "OtherInformation" },
        { "logical_name": "solar_notes", "type": "Multiline", "sharepoint_column": "Notes" },
        { "logical_name": "solar_active", "type": "Boolean", "sharepoint_column": "Active" }
      ],
      "add_lookups": [
        { "logical_name": "solar_dnogridoperator", "target_entity": "solar_dno", "sharepoint_column": "DNOGridOperator", "note": "Αφού δημιουργηθεί solar_dno" },
        { "logical_name": "solar_supervisor", "target_entity": "systemuser", "sharepoint_column": "Supervisor", "note": "Person or Group" }
      ]
    }
  ],
  "create_new_tables": [
    {
      "proposed_entity_name": "solar_dno",
      "sharepoint_source": "DNO",
      "primary_name_attribute": "solar_name",
      "description": "Δίκτυα διανομής (DNO) / Grid operators. Lookup από solar_location.",
      "key_attributes_from_sharepoint": ["Code", "Title", "EmergencyNumber", "Telephone", "Email", "Website", "Description", "Notes"]
    },
    {
      "proposed_entity_name": "solar_section",
      "sharepoint_source": "Sections",
      "primary_name_attribute": "solar_name",
      "description": "Τμήματα ανά location (strings, inverters κλπ). Location → solar_location.",
      "relationship_to_solar_location": "solar_location → solar_location (Lookup)"
    },
    {
      "proposed_entity_name": "solar_site_credentials",
      "sharepoint_source": "PVPlantsSiteCredentials",
      "primary_name_attribute": "solar_name",
      "description": "Διαπιστευτήρια ανά site. Σύνδεση με solar_location (όχι PVPlants).",
      "relationship_to_solar_location": "solar_location → solar_location (Lookup)",
      "key_attributes_from_sharepoint": ["Title", "IPAddress", "UsernamePassword", "PlantId → solar_locationid"]
    },
    {
      "proposed_entity_name": "solar_site_comments",
      "sharepoint_source": "CommentsRemarks",
      "primary_name_attribute": "solar_name",
      "description": "Σχόλια/παρατηρήσεις ανά site. SiteId/Location → solar_location.",
      "relationship_to_solar_location": "solar_location → solar_location (Lookup)",
      "key_attributes_from_sharepoint": ["Title", "Description", "SendEmail", "SendEmailTo", "SiteId → solar_locationid"]
    },
    {
      "proposed_entity_name": "solar_maintenance_team_per_location",
      "sharepoint_source": "MaintenanceTeamPerLocation",
      "primary_name_attribute": "solar_name",
      "description": "Ανάθεση ομάδων συντήρησης ανά location.",
      "relationship_to_solar_location": "solar_location → solar_location (Lookup)",
      "relationship_to_team": "solar_maintenance_team → solar_maintenance_team (Lookup)"
    }
  ],
  "relationships_using_solar_location_as_primary": [
    {
      "referencing_entity": "solar_location",
      "referencing_attribute": "solar_zones",
      "referenced_entity": "solar_location",
      "referenced_attribute": "solar_locationid",
      "type": "self_reference",
      "sharepoint_equivalent": "Locations.Zones > Locations.id"
    },
    {
      "referencing_entity": "solar_location",
      "referencing_attribute": "solar_dnogridoperator",
      "referenced_entity": "solar_dno",
      "referenced_attribute": "solar_dnoid",
      "when_created": "After solar_dno exists",
      "sharepoint_equivalent": "Locations.DNOGridOperator > DNO.id"
    },
    {
      "referencing_entity": "solar_site_credentials",
      "referencing_attribute": "solar_location",
      "referenced_entity": "solar_location",
      "referenced_attribute": "solar_locationid",
      "replaces_sharepoint": "PVPlantsSiteCredentials.SolarSite > PVPlants.id"
    },
    {
      "referencing_entity": "solar_site_comments",
      "referencing_attribute": "solar_location",
      "referenced_entity": "solar_location",
      "referenced_attribute": "solar_locationid",
      "replaces_sharepoint": "CommentsRemarks.SiteId / PVPlants"
    },
    {
      "referencing_entity": "solar_section",
      "referencing_attribute": "solar_location",
      "referenced_entity": "solar_location",
      "referenced_attribute": "solar_locationid",
      "sharepoint_equivalent": "Sections.Location > Locations.id"
    },
    {
      "referencing_entity": "solar_maintenance_team_per_location",
      "referencing_attribute": "solar_location",
      "referenced_entity": "solar_location",
      "referenced_attribute": "solar_locationid",
      "sharepoint_equivalent": "MaintenanceTeamPerLocation.Location > Locations.id"
    }
  ],
  "do_not_use_pvplants_as_primary": [
    "PVPlants",
    "PVPlantsSiteCredentials.SolarSite",
    "PVPlantsDNOStations.PlantId",
    "PVPlantsCCTVGateCodes.PlantId",
    "PVPlantsContactInfo",
    "PVPlantsSystemInfo.PlantId",
    "EquipmentTracking.PlantId",
    "PlantPreventative.PlantId",
    "CommentsRemarks.SiteId"
  ],
  "mapping_rule": "For each of the above SharePoint references, use solar_location (solar_locationid) as the target entity for 'Plant' or 'Site'.",

  "phase_2": {
    "purpose": "Φάση 2: Αποθήκες, εξοπλισμός, ανταλλακτικά, υπηρεσίες, ρυθμίσεις ανά site. Location/PlantId → solar_location.",
    "create_new_tables": [
      { "proposed_entity_name": "solar_supplier", "sharepoint_source": "Suppliers", "primary_name_attribute": "solar_name", "description": "Προμηθευτές.", "key_attributes_from_sharepoint": ["Code", "Title", "Description", "Notes", "Active"] },
      { "proposed_entity_name": "solar_part_category", "sharepoint_source": "PartsCategories", "primary_name_attribute": "solar_name", "description": "Κατηγορίες ανταλλακτικών. Parent → self.", "key_attributes_from_sharepoint": ["Code", "Title", "Description", "Level", "Parent", "Notes", "Active"] },
      { "proposed_entity_name": "solar_manufacturer_brand", "sharepoint_source": "ManufacturerBrands", "primary_name_attribute": "solar_name", "description": "Κατασκευαστές/μάρκες.", "key_attributes_from_sharepoint": ["Code", "Title", "Logo", "Description", "Website", "Notes", "Active"] },
      { "proposed_entity_name": "solar_equipment_category", "sharepoint_source": "EquipmentCategories", "primary_name_attribute": "solar_name", "description": "Κατηγορίες εξοπλισμού. Parent → self.", "key_attributes_from_sharepoint": ["Code", "Title", "Description", "MainType", "Parent", "Notes", "Active", "CategoryType"] },
