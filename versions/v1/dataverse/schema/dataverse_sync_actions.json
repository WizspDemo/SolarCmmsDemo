      { "proposed_entity_name": "solar_warehouse_to_location", "sharepoint_source": "WarehouseToLocation", "primary_name_attribute": "solar_name", "description": "Σύνδεση αποθήκης–location.", "key_lookups": ["Warehouse → solar_warehouse", "Location → solar_location"], "key_attributes_from_sharepoint": ["Title", "Warehouse", "Location", "Description"] },
      { "proposed_entity_name": "solar_warehouse_equipment_serial", "sharepoint_source": "WarehouseEquipmentSerial", "primary_name_attribute": "solar_name", "description": "Serial εξοπλισμού σε αποθήκη.", "key_lookups": ["Equipment → solar_equipment", "Warehouse → solar_warehouse"], "key_attributes_from_sharepoint": ["Title", "Equipment", "Warehouse", "SerialNumber", "Status", "Notes"] },
