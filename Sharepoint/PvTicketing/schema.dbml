  id integer [pk, increment]
  Title varchar(255) [not null] // Title
}

Table PlantRemedials {
  id integer [pk, increment]
  Title varchar(255) [not null] // Title
}

Table DNOs {
  id integer [pk, increment]
  Title varchar(255) [not null] // Title
}

Table Clients {
  id integer [pk, increment]
  Title varchar(255) [not null] // Title
}

