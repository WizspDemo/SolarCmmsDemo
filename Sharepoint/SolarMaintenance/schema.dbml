}

Table AssetsCategories {
  id integer [pk, increment]
  Code varchar(255) [unique] // Code
  Title varchar(255) [not null] // Title
  Description text // Description
  Parent integer // Lookup to AssetsCategories
  Notes text // Notes
  Active boolean // Active
}

Table LocationConfiguration {
  id integer [pk, increment]
  Title varchar(255) [not null] // Title
  Location integer // Lookup to Locations
  ItemType integer // Lookup to LocationConfigurationItemTypes
  Quantity integer // Quantity
  Description text // Description
  Notes text // Notes
  Active boolean // Active
}

Table LocationConfigurationItemTypes {
  id integer [pk, increment]
  Code varchar(255) [unique] // Code
  Title varchar(255) [not null] // Title
  Description text // Description
  Active boolean // Active
}

Table WarehouseEquipmentSerial {
  id integer [pk, increment]
  Title varchar(255) [not null] // Title
