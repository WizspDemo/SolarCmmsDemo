  Section integer // Lookup to Sections
  SerialNumber varchar(255) // Serial Number
  ManufacturerOrBrand integer // Lookup to ManufacturerBrands
  InstallationDate date // Installation Date
  WarrantyExpiry date // Warranty Expiry
