}

// Junction Tables for Many-to-Many Relationships

Table Locations_Zones {
  id integer [pk, increment]
  parent_id integer [ref: > Locations.id]
  child_id integer [ref: > Locations.id]
}

Table Tasks_Predecessors {
  id integer [pk, increment]
  parent_id integer [ref: > Tasks.id]
  child_id integer [ref: > Tasks.id]
}

