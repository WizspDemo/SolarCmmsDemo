// Solar Maintenance Database Schema
// Generated from SharePoint list definitions

Table Suppliers {
  id integer [pk, increment]
  Code varchar(255) [unique] // Code
  Title varchar(255) [not null] // Title
  Description text // Description
  Notes text // Notes
  Active boolean // Active
}

Table Equipment {
  id integer [pk, increment]
  Code varchar(255) [unique] // Code
  Title varchar(255) [not null] // Title
  Category integer // Lookup to EquipmentCategories
  Description text // Description
  ManufacturerID varchar(255) // ManufacturerID
  ManufacturerOrBrand integer // Lookup to ManufacturerBrands
  Supplier integer // Lookup to Suppliers
  StockManagement boolean // Stock Management
  Photo varchar(255) // Photo
  URL varchar(500) // URL
  Notes text // Notes
  Active boolean // Active
  CategoryType integer // Lookup to EquipmentCategories
  Serial boolean // Serial
}

Table Parts {
  id integer [pk, increment]
  Code varchar(255) [unique] // Code
  Title varchar(255) [not null] // Title
  Category integer // Lookup to PartsCategories
  Description text // Description
  Barcode varchar(255) [unique] // Barcode
  UPC varchar(255) [unique] // UPC
  ManufacturerID varchar(255) // ManufacturerID
  ManufacturerOrBrand integer // Lookup to ManufacturerBrands
  Supplier integer // Lookup to Suppliers
  StockManagement boolean // Stock Management
  Consumable boolean // Consumable
  Photo varchar(255) // Photo
  URL varchar(500) // URL
  MinQTY integer // MinQTY
  Notes text // Notes
  Active boolean // Active
}

Table DeviceChannels {
  id integer [pk, increment]
  Title varchar(255) [not null] // Name
  Alias varchar(255) [unique] // Alias
  Description text // Description
  UserAgentSubstrings text // Device Inclusion Rules (UserAgentSubstrings)
  Active boolean // Active
}

Table DNO {
  id integer [pk, increment]
  Code varchar(255) // Code
  Title varchar(255) [not null] // Title
  EmergencyNumber varchar(255) // Emergency Number
  Description text // Description
  Telephone varchar(255) // Telephone
  Email varchar(255) // Email
  Website varchar(500) // Website
  Notes text // Notes
}

Table CorrectiveTaskCategories {
  id integer [pk, increment]
  Code varchar(255) [unique] // Code
  Title varchar(255) [not null] // Title
  Description text // Description
  Parent integer // Lookup to CorrectiveTaskCategories
  Notes text // Notes
  Active boolean // Active
}

Table Locations {
  id integer [pk, increment]
  Code varchar(255) [unique] // Code
  Title varchar(255) [not null] // Name
  OpenDate date // Open Date
  CloseDate date // Close Date
  Stage varchar(255) // Stage
  CapacityMW decimal(18, 2) // Capacity MW
  AnnualOutputGWh decimal(18, 2) // Annual Output GWh
  Zones integer // Lookup to Locations
  StockManagement boolean // Stock Management
  ContainsSections boolean // Contains Sections
  Manager integer // Manager
  Description text // Description
  LandSizeHectares decimal(18, 2) // Land Size Hectares
  AddressDescription text // Address Description
  Street varchar(255) // Street
  ZipOrPostalCode varchar(255) // Zip or Postal Code
  StateOrProvince varchar(255) // State or Province
  Country integer // Lookup to Countries
  Latitude decimal(18, 2) // Latitude
  Longtitude decimal(18, 2) // Longtitude
  GoogleEarth varchar(500) // GoogleEarth
  EmbedMap text // Embed Map
  What3Words varchar(255) // What3Words
  Grazed boolean // Grazed
  LandOwnerFarmerDetails text // Land Owner/Farmer Details
  InverterManufacturer varchar(255) // Inverter Manufacturer
  InverterType varchar(255) // Inverter Type
  InverterModel varchar(255) // Inverter Model
  InverterQuantity integer // Inverter Quantity
  InverterTotal integer // Inverter Total
  InverterLVVoltage integer // Inverter LV Voltage
  InverterPower decimal(18, 2) // Inverter Power
  AssumedWarrantyPeriod integer // Assumed Warranty Period
  WarrantyExpiry date // Warranty Expiry
  EstimatedExpiry date // Estimated Expiry
  ModuleManufacturer varchar(255) // Module Manufacturer
  ModuleModel varchar(255) // Module Model
  ModuleQuantity integer // Module Quantity
  ModulePower decimal(18, 2) // Module Power
  ModuleVoc decimal(18, 2) // Module Voc
  ModuleIsc decimal(18, 2) // Module Isc
  ModuleLength decimal(18, 2) // Module Length
  ModuleWidth decimal(18, 2) // Module Width
  ModuleDepth decimal(18, 2) // Module Depth
  ModuleStructure varchar(255) // Module Structure
  Satellite3G4G varchar(255) // Satellite/3G/4G
  LANNetwork varchar(255) // LAN Network
  SCADAProvider varchar(255) // SCADA Provider
  ADASInstalled boolean // ADAS Installed
  DataLoggers varchar(255) // Data Loggers
  DNOGridOperator integer // Lookup to DNO
  DNOSizeKV varchar(255) // DNO Size (KV)
  DNOContact varchar(255) // DNO Contact
  DNOContact2 varchar(255) // DNO Contact2
  DNOContact3 varchar(255) // DNO Contact3
  SiteReferenceNumber varchar(255) // Site Reference Number
  HVContractor varchar(255) // HV Contractor
  TBootSub varchar(255) // T-Boot/sub
  TransformerQuantity integer // Transformer Quantity
  TransformerMake varchar(255) // Transformer Make
  TransformerModel varchar(255) // Transformer Model
  TransformerRatingKVA integer // Transformer Rating KVA
  Security varchar(255) // Security
  SecurityCodes text // Security Codes
  SiteAccessDetails text // Site Access Details
  AccessGateCodes text // Access Gate Codes
  ExportMeterLocation varchar(255) // Export Meter Location
  ExportMeterAccessDetails text // Export Meter Access Details
  Supervisor integer // Supervisor
  OtherInformation text // Other Information
  Notes text // Notes
  Active boolean // Active
}

Table Tasks {
  id integer [pk, increment]
  Title varchar(255) [not null] // Task Name
  Predecessors integer // Lookup to Tasks
  Priority varchar(255) // Priority
  Status varchar(255) // Status
  PercentComplete integer // % Complete
  AssignedTo integer // Assigned To
  TaskGroup integer // Task Group
  Description text // Description
  StartDate date // Start Date
  DueDate date // Due Date
  RelatedItems varchar(255) // Related Items
}

Table PublishedFeed {
  id integer [pk, increment]
  Title varchar(255) [not null] // Title
  Body text // Body
  PublishedDate datetime // Published Date
}

Table SiteCollectionDocuments {
  id integer [pk, increment]
  FileLeafRef varchar(255) [not null] // Name
  Title varchar(255) // Title
}

Table EquipmentCategories {
  id integer [pk, increment]
  Code varchar(255) [unique] // Code
  Title varchar(255) [not null] // Title
  Description text // Description
  MainType varchar(255) // Main Type
  Parent integer // Lookup to EquipmentCategories
  Notes text // Notes
  Active boolean // Active
  CategoryType varchar(255) // CategoryType
}

Table PartsCategories {
  id integer [pk, increment]
  Code varchar(255) [unique] // Code
  Title varchar(255) [not null] // Title
  Description text // Description
  Level varchar(255) // Level
